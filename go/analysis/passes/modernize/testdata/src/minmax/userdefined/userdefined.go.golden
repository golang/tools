package userdefined

// User-defined function with different name - should NOT be removed
func minimum(a, b int) int {
	if a < b {
		return a
	} else {
		return b
	}
}

// Method on a type - should NOT be removed
type MyType struct{}

func (m MyType) min(a, b int) int {
	if a < b {
		return a
	} else {
		return b
	}
}


